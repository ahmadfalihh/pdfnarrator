# === GEMINI API KEYS (wajib minimal 1) ===
GEMINI_KEY_1=
GEMINI_KEY_2=
GEMINI_KEY_3=

# === NARASI ===
# Pilihan: Profesional & Formal, Santai & Kasual, Edukatif & Informatif,
#          Inspiratif & Memotivasi, Humoris & Menyenangkan, Dramatis & Epik,
#          Misterius & Bikin Penasaran, Gaya Pembaca Berita, Storytelling (Mendongeng),
#          Puitis & Estetik, Gaya Pitching Bisnis (Meyakinkan)
NARRATION_STYLE=Profesional & Formal

# Pilihan Voice: Aoede, Zephyr, Puck, Charon, Kore, Fenrir, Leda, Orus, Callirrhoe, Autonoe, Enceladus
NARRATOR_VOICE=Zephyr

# === ANTI RATE-LIMIT ===
# Jeda antar slide dalam detik (rekomendasi 15 untuk 1 key, 8 untuk 3 key)
SLIDE_DELAY=15

# === UPLOAD OPTIONS ===
UPLOAD_DRIVE=true
UPLOAD_YOUTUBE=true
DRIVE_FOLDER_ID=

# === YOUTUBE ===
# Isi jika punya >1 channel, kosongkan jika hanya punya 1 channel (otomatis dipilih)
YOUTUBE_CHANNEL_ID=
# Privacy: private, unlisted, public
YOUTUBE_PRIVACY=private

